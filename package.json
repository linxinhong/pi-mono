{
	"name": "@mariozechner/pi-feishu",
	"version": "0.55.3",
	"description": "Feishu bot that delegates messages to the pi coding agent",
	"type": "module",
	"bin": {
		"pi-feishu": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && chmod +x dist/main.js",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@anthropic-ai/sandbox-runtime": "^0.0.16",
		"@larksuiteoapi/node-sdk": "^1.37.0",
		"@mariozechner/pi-agent-core": "^0.55.3",
		"@mariozechner/pi-ai": "^0.55.3",
		"@mariozechner/pi-coding-agent": "^0.55.3",
		"@sinclair/typebox": "^0.34.0",
		"chalk": "^5.6.2",
		"croner": "^9.1.0",
		"diff": "^8.0.2",
		"dotenv": "^16.4.5",
		"express": "^4.21.0",
		"helmet": "^8.0.0"
	},
	"devDependencies": {
		"@types/diff": "^7.0.2",
		"@types/express": "^4.17.21",
		"@types/node": "^24.3.0",
		"typescript": "^5.7.3"
	},
	"keywords": [
		"feishu",
		"bot",
		"ai",
		"agent",
		"lark"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/badlogic/pi-mono.git",
		"directory": "packages/pi-feishu"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
